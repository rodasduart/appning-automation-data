{
  "packageName": "com.spotify.music",
  "screens": {
    "song_player_screen": {
      "strategy": "MASK_DYNAMIC_AREAS", 
      "selectors": [
        "com.android.car.media:id/playback_seek_bar_container",
        "com.android.car.media:id/current_time"
        ]
    },
    "settings_screen": {
      "strategy": "KEEP_ONLY_HEADER",
      "selectors": [
        { "type": "id", "value": "com.spotify.music:id/toolbar" }
      ]
    },
    "non_liked_player_button": {
      "strategy": "KEEP_ONLY_HEADER",
      "selectors": [
        {
          "type": "class",
          "value": "android.widget.ImageButton",
          "index": 3
        }
      ]
    }
  }
}

